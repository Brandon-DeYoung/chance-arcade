{
  "name": "chance-arcade",
  "version": "1.0.0",
  "description": "A local-first portrait wheel and physics marble race for meetings and streams.",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node scripts/launch.mjs",
    "test": "npm run build && node --import tsx --test tests/*.test.*",
    "test:unit": "node --import tsx --test tests/*.test.*",
    "lint": "eslint .",
    "check": "npm run lint && npm run test",
    "benchmark": "node --import tsx scripts/benchmark-physics.ts"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.13"
  },
  "type": "module"
}
